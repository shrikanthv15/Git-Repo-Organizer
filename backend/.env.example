PROJECT_NAME="Repo Gardener (Dev)"

# === GitHub OAuth ===
GITHUB_CLIENT_ID="Ov23li4fEHcW2f7yiRhp"
GITHUB_CLIENT_SECRET="f72979e998aa61108d92e1d856c1cd3367aa7671"

# === LLM (LiteLLM) ===
LITELLM_API_KEY=""
LLM_MODEL="gpt-4o-mini"
LITELLM_API_BASE=""

# === E5 guardrails ===
# Reject an LLM request when estimated cost exceeds this many USD.
# Default $0.50 is comfortable headroom for normal gpt-4o-mini calls
# (typical $0.001 - $0.01) and trips when something accidentally feeds
# the LLM a massive prompt. See app/services/llm_service.py.
LLM_MAX_COST_PER_REQUEST_USD="0.50"

# Passed to LiteLLM as max_tokens (caps OUTPUT) AND used as the
# pre-flight INPUT-prompt size check: a prompt larger than this would
# leave no room for output under most context windows.
LLM_MAX_TOKENS_PER_REQUEST="4000"

# === E4 structured logging ===
# Backend log format. "json" (default in prod) emits one JSON object per
# log line with bound context (request_id, workflow_id, etc).
# "human" gives colorized dev-friendly output.
LOG_FORMAT="json"
LOG_LEVEL="INFO"

# === DB (set automatically in docker-compose) ===
# DATABASE_URL="postgresql://gardener:gardener_secret@localhost:5432/gardener"

# === Temporal (set automatically in docker-compose) ===
# TEMPORAL_ADDRESS="localhost:7233"

# === CORS ===
# Comma-separated list of allowed frontend origins (leave empty for permissive dev mode).
FRONTEND_URL=""
